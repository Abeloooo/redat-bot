{
  "name": "telegram-bot",
  "version": "1.0.0",
  "description": "Redat AI Telegram Bot",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node index.ts",
    "postinstall": "node -e \"if (process.platform !== 'win32') { require('child_process').execSync('npm rebuild better-sqlite3 --build-from-source', { stdio: 'inherit' }) }\""
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "date-fns": "^4.4.0",
    "dotenv": "^16.6.1",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "telegraf": "^4.16.3",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}